HOST=127.0.0.1
PORT=8090

# Optional OpenAI-compatible chat-completions endpoint.
# Kimi example:
# AGENT_LLM_API_URL=https://api.moonshot.cn/v1/chat/completions
# AGENT_LLM_MODEL=kimi-k2.6
# AGENT_LLM_TEMPERATURE=1
AGENT_LLM_API_URL=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=
AGENT_LLM_TEMPERATURE=1

# Optional SQLite checkpoint file. Leave empty to use in-memory checkpoints.
AGENT_CHECKPOINT_DB=./data/checkpoints.sqlite3
# Embedding API（可选，用于语义相似度评分）
# AGENT_EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
# AGENT_EMBEDDING_API_KEY=sk-xxx
# AGENT_EMBEDDING_MODEL=text-embedding-3-small
